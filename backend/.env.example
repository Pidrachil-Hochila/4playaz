# 4PLAYAZ Backend — пример конфигурации
# Скопируй в .env и заполни своими значениями.

# ─── ОБЯЗАТЕЛЬНО ────────────────────────────────────────────
# Секрет для подписи JWT токенов (любая длинная случайная строка)
JWT_SECRET=

# Хотя бы один админ. Имя пользователя — между ADMIN_ и _PASSWORD.
# Пример ниже создаст логин "admin" с указанным паролем.
ADMIN_ADMIN_PASSWORD=

# Опционально: TOTP-секрет (если не задан, сгенерируется через /api/admin/setup-totp/<username>)
# TOTP_SECRET_ADMIN=

# ─── ОПЦИОНАЛЬНО: Supabase ──────────────────────────────────
# Если не заданы — заказы не сохраняются в БД, но платежи работают.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── ОПЦИОНАЛЬНО: ЮКасса ────────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ─── ОПЦИОНАЛЬНО: СДЭК ──────────────────────────────────────
# Без этих ключей расчёт стоимости доставки СДЭК отключён.
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
# Тестовая среда: https://api.edu.cdek.ru/v2 ; боевая: https://api.cdek.ru/v2
CDEK_API_URL=https://api.edu.cdek.ru/v2

# ─── ПРОЧЕЕ ─────────────────────────────────────────────────
SITE_URL=http://localhost:3000
PORT=3001
