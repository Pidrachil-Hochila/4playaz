# 4PLAYAZ Frontend — пример конфигурации
# Скопируй в .env и поправь под своё окружение.

# ─── ОБЯЗАТЕЛЬНО ───────────────────────────────────────────
# URL бэкенда: localhost:3001 в dev, https://api.4playaz.ru на проде.
# Если пустой — фронт будет стучаться по относительному пути и
# админка /admin/orders НЕ увидит данные.
NUXT_PUBLIC_API_BASE=http://localhost:3001

# ─── ОПЦИОНАЛЬНО ───────────────────────────────────────────
# Яндекс API ключ для виджета СДЭК (карта пунктов выдачи)
# NUXT_PUBLIC_YANDEX_API_KEY=

# Путь до прокси СДЭК на бэкенде (обычно /api/cdek)
# NUXT_PUBLIC_CDEK_SERVICE_PATH=/api/cdek
